{
  "manifest_version": 3,
  "name": "ChatGPT Performance Booster",
  "version": "1.0.0",
  "description": "Booste les performances de ChatGPT en limitant le rendu des longues conversations et en reduisant les effets couteux du navigateur.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "ChatGPT Performance Booster",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_start"
    }
  ]
}
